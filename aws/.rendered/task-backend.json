{
  "family": "ev2-cloud-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::848125594132:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "mysql",
      "image": "mysql:8.0",
      "essential": true,
      "environment": [
        { "name": "MYSQL_ROOT_PASSWORD", "value": "root" },
        { "name": "MYSQL_DATABASE", "value": "tienda_cloud" }
      ],
      "portMappings": [
        { "containerPort": 3306, "protocol": "tcp" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "mysqladmin ping -h 127.0.0.1 -uroot -proot --silent"],
        "interval": 10,
        "timeout": 5,
        "retries": 10,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ev2-cloud",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "mysql",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "backend",
      "image": "848125594132.dkr.ecr.us-east-2.amazonaws.com/ev2-cloud-backend:latest",
      "essential": true,
      "dependsOn": [
        { "containerName": "mysql", "condition": "HEALTHY" }
      ],
      "environment": [
        { "name": "DB_USER", "value": "root" },
        { "name": "DB_PASSWORD", "value": "root" },
        { "name": "DB_HOST", "value": "127.0.0.1" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "DB_NAME", "value": "tienda_cloud" },
        { "name": "APP_PAGOS_URL", "value": "http://app-pagos.ev2-cloud.local:8002" }
      ],
      "portMappings": [
        { "containerPort": 8000, "protocol": "tcp" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ev2-cloud",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "backend",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
