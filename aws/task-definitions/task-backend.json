{
  "family": "${PROJECT_NAME}-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "${EXEC_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "mysql",
      "image": "mysql:8.0",
      "essential": true,
      "environment": [
        { "name": "MYSQL_ROOT_PASSWORD", "value": "root" },
        { "name": "MYSQL_DATABASE", "value": "tienda_cloud" }
      ],
      "portMappings": [
        { "containerPort": 3306, "protocol": "tcp" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${LOG_GROUP}",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "mysql",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "backend",
      "image": "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${PROJECT_NAME}-backend:latest",
      "essential": true,
      "dependsOn": [
        { "containerName": "mysql", "condition": "START" }
      ],
      "environment": [
        { "name": "DB_USER", "value": "root" },
        { "name": "DB_PASSWORD", "value": "root" },
        { "name": "DB_HOST", "value": "127.0.0.1" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "DB_NAME", "value": "tienda_cloud" },
        { "name": "APP_PAGOS_URL", "value": "${APP_PAGOS_URL}" }
      ],
      "portMappings": [
        { "containerPort": 8000, "protocol": "tcp" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${LOG_GROUP}",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "backend",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
