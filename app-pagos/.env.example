# Configuración de MercadoPago
MP_ACCESS_TOKEN=your_mercadopago_access_token_here
MP_PUBLIC_KEY=your_mercadopago_public_key_here

# URLs de redirección después del pago
MP_SUCCESS_URL=https://www.mercadopago.cl/success
MP_FAILURE_URL=https://www.mercadopago.cl/failure
MP_PENDING_URL=https://www.mercadopago.cl/pending

# URL del webhook para notificaciones de MercadoPago
MP_WEBHOOK_URL=https://your-domain.com/pagos/webhook
